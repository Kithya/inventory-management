NODE_ENV=development
PORT=8000

# Runtime app connection. Use Neon's pooled hostname for deployed app traffic.
DATABASE_URL=postgresql://USER:PASSWORD@HOST-pooler.REGION.aws.neon.tech/DB?sslmode=require

# Direct connection for Prisma CLI migrations/introspection.
DIRECT_URL=postgresql://USER:PASSWORD@HOST.REGION.aws.neon.tech/DB?sslmode=require

CLIENT_ORIGINS=http://localhost:3000
APP_URL=http://localhost:3000
AUTH_REQUIRED=false

# Required when AUTH_REQUIRED=true. Use a long random value, 32+ chars.
JWT_ACCESS_SECRET=change-this-development-secret-with-64-random-characters
ACCESS_TOKEN_TTL_MINUTES=15
REFRESH_TOKEN_TTL_DAYS=7
REFRESH_COOKIE_NAME=inventory_refresh
INVITE_TOKEN_TTL_DAYS=7
RESET_TOKEN_TTL_MINUTES=30
